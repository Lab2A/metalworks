{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "metalworks",
  "description": "Open-source marketing research and Reddit engagement: demand reports from real conversations, as a library, CLI, MCP server, and Claude Code plugin.",
  "colors": {
    "primary": "#111111",
    "light": "#f5f5f5",
    "dark": "#111111"
  },
  "favicon": "/favicon.svg",
  "redirects": [
    {
      "source": "/",
      "destination": "/docs"
    }
  ],
  "navigation": {
    "groups": [
      {
        "group": "Get started",
        "pages": ["docs/index", "docs/quickstart", "docs/concepts"]
      },
      {
        "group": "The full arc",
        "pages": ["docs/the-arc"]
      },
      {
        "group": "Guides",
        "pages": [
          "docs/guide-demand-research",
          "docs/guide-positioning-landscape",
          "docs/guide-design",
          "docs/guide-build",
          "docs/guide-launch-growth",
          "docs/guide-reddit-engagement",
          "docs/build-your-own"
        ]
      },
      {
        "group": "How-to guides",
        "pages": [
          "docs/model-configuration",
          "docs/how-to-custom-chatmodel",
          "docs/how-to-custom-corpus",
          "docs/how-to-custom-store"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "docs/building-blocks",
          "docs/reference-client",
          "docs/reference-cli",
          "docs/reference-mcp",
          "docs/reference-protocols"
        ]
      },
      {
        "group": "Explanation",
        "pages": ["docs/explanation-provenance", "docs/for-coding-agents"]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Usage policy",
        "href": "https://github.com/Lab2A/metalworks/blob/main/USAGE_POLICY.md"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/Lab2A/metalworks"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Lab2A/metalworks"
    }
  }
}
